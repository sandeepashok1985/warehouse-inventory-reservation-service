					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-API-Key",
								"value": "{{apiKey}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/health",
							"host": ["{{baseUrl}}"],
							"path": ["health"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', () => {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response has STATUS and DATABASE fields', () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property('STATUS');",
									"    pm.expect(json).to.have.property('DATABASE');",
									"});"
								]
							}
						}
					]
